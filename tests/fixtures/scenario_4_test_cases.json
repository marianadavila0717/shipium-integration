  "invalid_dimensions": {
    "name": "throws_error_for_invalid_dimensions",
    "description": "Should throw error for malformed dimension string",
    "testCases": [
      {
        "input_dims": "10x8",
        "expected_error": "items[0].dims: Invalid dimension format: must be LxWxH"
      },
      {
        "input_dims": "axbxc",
        "expected_error": "items[0].dims: Invalid dimension format: dimensions must be numbers"
      },
      {
        "input_dims": "10x0x6",
        "expected_error": "items[0].dims: All dimensions must be greater than 0"
      },
      {
        "input_dims": "",
        "expected_error": "items[0].dims: Dimensions cannot be empty"
      }
    ],
