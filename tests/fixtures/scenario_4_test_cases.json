{
  "test_case_structure": {
    "description": "Each test case in the Scenario 4 spec includes these fields (see assessment markdown)",
    "fields": [
      { "field": "name", "role": "Descriptive test name" },
      { "field": "description", "role": "What this tests" },
      { "field": "input", "role": "Customer OMS order (when applicable)" },
      { "field": "expected", "role": "Shipium API order or partial object for brevity" },
      { "field": "expected_error", "role": "message and type when validation must fail" },
      { "field": "note", "role": "Extra context (e.g. partial expected, street2 omitted)" },
      { "field": "testCases", "role": "Sub-case table (e.g. weight rows, dimension strings, invalid dims/emails)" }
    ]
  },
  "happy_path": [
