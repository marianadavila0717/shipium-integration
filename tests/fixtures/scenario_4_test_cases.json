  "weight_conversion": {
    "decimal_ounces_to_pounds": {
      "name": "converts_decimal_ounces_to_pounds",
      "description": "Correctly converts fractional ounces to pounds",
      "input": {
        "orderNumber": "ORD-2026-004",
        "orderDate": "2026-01-15T13:00:00Z",
        "customer": {
          "custId": "CUST-111",
          "fullName": "Alice Williams",
          "email": "alice@example.com",
          "shippingAddr": {
            "street1": "111 Maple Dr",
            "city": "Austin",
            "state": "TX",
            "zip": "78701",
            "country": "US"
          }
        },
        "items": [
          {
            "sku": "LIGHT-001",
            "description": "Light Item",
            "qty": 1,
            "weight_oz": 12.5,
            "dims": "5x4x3"
          }
        ],
        "shipFromWarehouse": "DC-CENTRAL-01",
        "requestedShipDate": "2026-01-16",
        "serviceLevel": "OVERNIGHT"
      },
      "expected": {
        "items": [
          {
            "weight": {
              "value": 0.78125,
              "unit": "lb"
            }
          }
        ]
      },
      "note": "12.5 oz / 16 = 0.78125 lb - partial object shown for brevity"
    },
    "various_weights": {
      "description": "Test 5 from spec: table of ounce inputs, expected pounds, and per-row note",
      "testCases": [
        {
          "input_weight_oz": 8,
          "expected_weight_lb": 0.5,
          "note": "8 oz = 0.5 lb"
        },
        {
          "input_weight_oz": 16,
          "expected_weight_lb": 1.0,
          "note": "16 oz = 1 lb"
        },
        {
          "input_weight_oz": 32,
          "expected_weight_lb": 2.0,
          "note": "32 oz = 2 lb"
        },
        {
          "input_weight_oz": 48,
          "expected_weight_lb": 3.0,
          "note": "48 oz = 3 lb"
        }
      ],
